---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Webtoons | Manga Anime Webtoon" description="Featured webtoons and recommendations.">
  <section class="w-full bg-canvas py-section px-lg">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-xl">
      <div class="flex flex-col gap-sm">
        <p class="font-mono text-caption uppercase tracking-wider text-mute">Webtoons</p>
        <h1 class="text-display-lg font-semibold tracking-[-1.28px] text-ink">Featured Webtoons</h1>
        <p class="text-body-lg text-body max-w-[720px]">Below are some upcoming and recommended webtoons. No links—just names and short descriptions.</p>
      </div>

      <div class="space-y-lg">
        <ul class="space-y-md">
          <li>
            <h3 class="text-display-sm font-semibold text-ink">Lore of the Fallen</h3>
            <p class="text-body-sm text-body text-mute">A dark fantasy following a fallen knight rebuilding his path while secrets of the old world emerge. Expect sweeping landscapes and political intrigue.</p>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Neon Alley</h3>
            <p class="text-body-sm text-body text-mute">A cyber-noir slice-of-life about street merchants and underground hackers in a neon metropolis. Stylish panels and character-driven scenes lead the way.</p>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Midnight Delivery</h3>
            <p class="text-body-sm text-body text-mute">A supernatural courier service that delivers more than packages—each job reveals a new mystery. Fast-paced with episodic thrills.</p>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Cherry Blossom Days</h3>
            <p class="text-body-sm text-body text-mute">A heartwarming romance set in a small town during cherry blossom season. Gentle storytelling with beautiful everyday moments.</p>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Cyber Cafe Chronicles</h3>
            <p class="text-body-sm text-body text-mute">An anthology of short stories centered around a city cafe where people from all walks of life cross paths. Quirky, melancholic, and often surprising.</p>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
