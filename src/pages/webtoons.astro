---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Webtoons | Manga Anime Webtoon" description="Featured webtoons and recommendations.">
  <section class="w-full bg-canvas py-section px-lg">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-xl">
      <div class="flex flex-col gap-sm">
        <p class="font-mono text-caption uppercase tracking-wider text-mute">Webtoons</p>
        <h1 class="text-display-lg font-semibold tracking-[-1.28px] text-ink">Featured Webtoons</h1>
        <p class="text-body-lg text-body max-w-[720px]">Below are some upcoming and recommended webtoons. No links—just names and short descriptions.</p>
      </div>

      <div class="space-y-lg">
        <ul class="space-y-md">
          <li>
            <h3 class="text-display-sm font-semibold text-ink">Omniscient Reader's Viewpoint</h3>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">The Beginning After the End</h3>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Tower of God</h3>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Eleceed</h3>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Nano Machine</h3>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Return of the Mount Hua Sect</h3>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">Pick Me Up, Infinite Gacha</h3>
          </li>

          <li>
            <h3 class="text-display-sm font-semibold text-ink">SSS-Class Suicide Hunter</h3>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
