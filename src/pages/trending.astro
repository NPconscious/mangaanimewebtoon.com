---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Trending | Manga Anime Webtoon" description="Current trending picks across anime, webtoons, and manga.">
  <section class="w-full bg-canvas py-section px-lg">
    <div class="max-w-[900px] mx-auto">
      <div class="bg-canvas-soft p-lg rounded-lg shadow-[var(--shadow-level-3)] border border-hairline">
        <h2 class="font-mono text-caption uppercase tracking-wider text-mute mb-sm">Trending</h2>
        <p class="text-display-sm font-semibold text-ink mb-md">Trending picks across anime, webtoons, and manga</p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-md">
          <div>
            <h3 class="font-semibold text-ink mb-xs">Anime</h3>
            <ol class="list-decimal list-inside text-body-sm text-body text-mute space-y-2">
              <li>Solo Leveling</li>
              <li>Dandadan</li>
              <li>Frieren: Beyond Journey's End</li>
              <li>Kaiju No. 8</li>
              <li>The Apothecary Diaries</li>
              <li>Blue Lock</li>
            </ol>
          </div>

          <div>
            <h3 class="font-semibold text-ink mb-xs">Manhwa</h3>
            <ol class="list-decimal list-inside text-body-sm text-body text-mute space-y-2">
              <li>Omniscient Reader's Viewpoint</li>
              <li>The Beginning After the End</li>
              <li>Nano Machine</li>
              <li>Return of the Mount Hua Sect</li>
              <li>Pick Me Up, Infinite Gacha</li>
              <li>Academy's Genius Swordmaster</li>
            </ol>
          </div>

          <div>
            <h3 class="font-semibold text-ink mb-xs">Manga</h3>
            <ol class="list-decimal list-inside text-body-sm text-body text-mute space-y-2">
              <li>One Piece</li>
              <li>Sakamoto Days</li>
              <li>Kagurabachi</li>
              <li>Chainsaw Man</li>
              <li>Spy x Family</li>
              <li>Jujutsu Kaisen</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
