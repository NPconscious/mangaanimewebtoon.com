---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
---

<Layout title="Manga Anime Webtoon">
  
  <!-- Hero Section -->
  <section class="relative w-full overflow-hidden bg-gradient-to-br from-[#f8fbff] via-[#fdf7ff] to-[#fff4f3] py-section px-lg flex flex-col items-center text-center">
    <!-- Background glow -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-24 left-1/2 h-[420px] w-[420px] -translate-x-1/2 rounded-full bg-[#7b61ff]/10 blur-3xl"></div>
      <div class="absolute top-16 right-10 h-[360px] w-[360px] rounded-full bg-[#00c4ff]/10 blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-[900px] flex flex-col items-center gap-md rounded-[40px] border border-white/70 bg-white/80 p-[40px] shadow-[0_30px_120px_-80px_rgba(15,23,42,0.18)] backdrop-blur-xl">
      <div class="inline-flex items-center gap-2 rounded-full border border-hairline bg-white/90 px-sm py-xs text-body-sm font-semibold text-ink shadow-sm backdrop-blur">
        <span>✨</span>
        <span>New Season Announcements</span>
      </div>
      <h1 class="text-display-xl font-semibold tracking-[-2.4px] text-ink max-w-[15ch]">
        The heartbeat of anime and manga culture...
      </h1>
      <p class="text-body-lg text-body max-w-[600px]">
        Discover the latest breaking news, deep-dive reviews, and webtoon recommendations tailored for the ultimate fan experience.
      </p>
    </div>
  </section>

  <!-- Section Previews -->
  <section class="w-full bg-transparent py-5xl px-lg">
    <div class="max-w-[1400px] mx-auto rounded-[40px] border border-white/60 bg-white/80 p-lg shadow-[0_40px_120px_-80px_rgba(15,23,42,0.15)] backdrop-blur-xl flex flex-col gap-xl">
      <Card class="p-lg border border-hairline bg-white shadow-[0_24px_48px_-28px_rgba(15,23,42,0.35)] w-full">
        <div class="flex flex-col gap-lg lg:flex-row lg:items-start">
          <div class="overflow-hidden rounded-[28px] border border-slate-200 lg:w-[320px] w-full h-[320px] bg-canvas">
            <img src="/latest-anouncement.jpg" alt="Latest announcement" class="h-full w-full object-cover" />
          </div>
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <p class="font-mono text-caption uppercase tracking-wider text-indigo-500">News</p>
              <h2 class="text-display-sm font-semibold text-ink">Latest announcements</h2>
              <p class="text-body-sm text-body text-mute mt-sm">
                Stay updated with release dates, studio news, and major anime industry stories.<br />
                Get fast summaries from the biggest announcements.<br />
                Perfect for fans tracking new season updates.
              </p>
            </div>
            <Button href="/news" variant="secondary" size="sm">View News</Button>
          </div>
        </div>
      </Card>

      <Card class="p-lg border border-indigo-100 bg-[#eef2ff] shadow-[0_20px_50px_-32px_rgba(99,102,241,0.45)] w-full">
        <div class="flex flex-col gap-lg lg:flex-row-reverse lg:items-start">
          <div class="overflow-hidden rounded-[28px] border border-indigo-200 shadow-sm lg:w-[320px] w-full h-[320px] bg-canvas">
            <img src="/review.jpg" alt="Review artwork" class="h-full w-full object-cover" />
          </div>
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <p class="font-mono text-caption uppercase tracking-wider text-indigo-600">Reviews</p>
              <h2 class="text-display-sm font-semibold text-ink">Thoughtful analysis</h2>
              <p class="text-body-sm text-body text-mute mt-sm">
                Read in-depth opinions across anime, manga, and webtoons.<br />
                Discover ratings and recommendations from our team.<br />
                Find the best picks for your next watch or read.
              </p>
            </div>
            <Button href="/reviews" variant="secondary" size="sm">See Reviews</Button>
          </div>
        </div>
      </Card>

      <Card class="p-lg border border-cyan-100 bg-[#ecfeff] shadow-[0_20px_50px_-32px_rgba(6,182,212,0.35)] w-full">
        <div class="flex flex-col gap-lg lg:flex-row lg:items-start">
          <div class="overflow-hidden rounded-[28px] border border-cyan-200 shadow-sm lg:w-[320px] w-full h-[320px] bg-canvas">
            <img src="/webtoon.jpg" alt="Webtoon showcase" class="h-full w-full object-cover" />
          </div>
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <p class="font-mono text-caption uppercase tracking-wider text-cyan-600">Webtoons</p>
              <h2 class="text-display-sm font-semibold text-ink">Starter pack</h2>
              <p class="text-body-sm text-body text-mute mt-sm">
                Explore curated webtoon recommendations for every genre.<br />
                Start with fan favorites and binge-worthy stories.<br />
                A great list for new readers and longtime fans.
              </p>
            </div>
            <Button href="/webtoons" variant="secondary" size="sm">Browse Webtoons</Button>
          </div>
        </div>
      </Card>

      <Card class="p-lg border border-rose-100 bg-[#fff1f2] shadow-[0_20px_50px_-32px_rgba(244,63,94,0.25)] w-full">
        <div class="flex flex-col gap-lg lg:flex-row-reverse lg:items-start">
          <div class="overflow-hidden rounded-[28px] border border-rose-200 shadow-sm lg:w-[320px] w-full h-[320px] bg-canvas">
            <img src="/trending.jpg" alt="Trending highlights" class="h-full w-full object-cover" />
          </div>
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <p class="font-mono text-caption uppercase tracking-wider text-rose-600">Trending</p>
              <h2 class="text-display-sm font-semibold text-ink">What’s hot now</h2>
              <p class="text-body-sm text-body text-mute mt-sm">
                Discover current fan favorites across anime, manga, and manhwa.<br />
                Stay on top of the latest trends and must-see titles.<br />
                See what the community is talking about now.
              </p>
            </div>
            <Button href="/trending" variant="secondary" size="sm">Check Trending</Button>
          </div>
        </div>
      </Card>
    </div>
  </section>
</Layout>
