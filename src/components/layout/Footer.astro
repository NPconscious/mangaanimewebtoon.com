    <div class="flex flex-col gap-sm">
      <h3 class="font-mono text-caption uppercase tracking-wider text-ink mb-xs">Community</h3>
      <a href="#" class="text-body-sm hover:text-link transition-colors">Forums</a>
      <a href="#" class="text-body-sm hover:text-link transition-colors">Discord Server</a>
      <a href="#" class="text-body-sm hover:text-link transition-colors">Twitter / X</a>
      <a href="#" class="text-body-sm hover:text-link transition-colors">Submit a Tip</a>
