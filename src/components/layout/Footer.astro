    <div class="flex flex-col gap-sm">
      <h3 class="font-mono text-caption uppercase tracking-wider text-ink mb-xs">Content</h3>
      <a href="/news" class="text-body-sm hover:text-link transition-colors">Latest News</a>
      <a href="/reviews" class="text-body-sm hover:text-link transition-colors">Reviews</a>
      <a href="/webtoons" class="text-body-sm hover:text-link transition-colors">Webtoon Discoveries</a>
