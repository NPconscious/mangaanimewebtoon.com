---
import Button from '../ui/Button.astro';
---

<nav class="sticky top-0 z-50 w-full h-[64px] px-sm md:px-lg bg-white/85 backdrop-blur-xl border-b border-hairline shadow-sm flex items-center justify-between">
  <div class="flex items-center gap-md">
    <a href="/" class="text-ink font-semibold text-[18px] tracking-tight flex items-center gap-xs">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L2 19.7778H22L12 2Z" fill="currentColor"/>
      </svg>
      <span>Manga Anime Webtoon</span>
    </a>
  </div>

  <div class="hidden md:flex items-center gap-xs">
    <a href="/news" class="text-body text-[14px] font-normal px-sm py-xs rounded-full hover:bg-canvas-soft transition-colors">News</a>
    <a href="/reviews" class="text-body text-[14px] font-normal px-sm py-xs rounded-full hover:bg-canvas-soft transition-colors">Reviews</a>
    <a href="/webtoons" class="text-body text-[14px] font-normal px-sm py-xs rounded-full hover:bg-canvas-soft transition-colors">Webtoons</a>
    <a href="/trending" class="text-body text-[14px] font-normal px-sm py-xs rounded-full hover:bg-canvas-soft transition-colors">Trending</a>
